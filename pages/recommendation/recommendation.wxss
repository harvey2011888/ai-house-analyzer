/**
 * 推荐结果页样式 - 专业版
 * 使用 app.wxss 中定义的 CSS 变量
 */

.result-container {
  min-height: 100vh;
  background: var(--background-color);
  padding: var(--space-3);
  box-sizing: border-box;
}

/* ========== AI 分析加载状态 ========== */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx var(--space-4);
}

.loading-icon {
  font-size: 140rpx;
  margin-bottom: var(--space-4);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.15);
    opacity: 0.8;
  }
}

.loading-text {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: var(--space-2);
}

.loading-sub {
  font-size: var(--font-size-md);
  color: var(--text-color-secondary);
  margin-bottom: var(--space-4);
}

.loading-progress {
  width: 400rpx;
  height: 8rpx;
  background: var(--gray-200);
  border-radius: var(--radius-full);
  overflow: hidden;
  margin-bottom: var(--space-2);
}

.loading-progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--primary) 0%, var(--primary-light) 100%);
  border-radius: var(--radius-full);
  animation: progress 2s ease-in-out infinite;
}

@keyframes progress {
  0% {
    width: 0%;
    transform: translateX(-100%);
  }
  50% {
    width: 60%;
    transform: translateX(0%);
  }
  100% {
    width: 100%;
    transform: translateX(100%);
  }
}

.loading-steps {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-1);
  margin-top: var(--space-3);
}

.loading-step {
  font-size: var(--font-size-sm);
  color: var(--gray-400);
  opacity: 0.6;
  transition: all 0.3s ease;
}

.loading-step.active {
  color: var(--primary);
  opacity: 1;
  font-weight: 500;
}

/* ========== AI 综合建议卡片 ========== */
.advice-card {
  background: linear-gradient(135deg, var(--primary-bg) 0%, #EFF6FF 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-4);
  border-left: 6rpx solid var(--primary);
  box-shadow: var(--shadow-md);
}

.advice-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: var(--space-2);
  display: flex;
  align-items: center;
  gap: var(--space-1);
}

.advice-text {
  font-size: var(--font-size-md);
  color: var(--text-color-secondary);
  line-height: 1.7;
}

/* ========== 对比区域标题 ========== */
.compare-section {
  margin-bottom: var(--space-4);
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-3);
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--text-color);
}

.fallback-tag {
  font-size: var(--font-size-xs);
  color: var(--warning);
  background: var(--warning-light);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  font-weight: 500;
}

/* ========== TOP 推荐卡片 - 单列布局 ========== */
.top-cards-container {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin-bottom: var(--space-3);
}

.top-card {
  background: var(--background-color-white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  overflow: hidden;
  position: relative;
  width: 100%;
  display: flex;
  flex-direction: column;
}

.top-card-header {
  display: flex;
  flex-direction: column;
  padding: var(--space-2);
  gap: var(--space-2);
}

.top-card-image {
  width: 100%;
  height: 120rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, var(--gray-200) 0%, var(--gray-300) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}

.top-card-image::before {
  content: '🏠';
  font-size: 60rpx;
  opacity: 0.3;
}

.top-card-image-placeholder {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.3) 0%, transparent 100%);
}

.top-card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.top-card-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-1);
}

.top-card-name {
  font-size: var(--font-size-md);
  font-weight: 700;
  color: var(--text-color);
  line-height: 1.2;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.top-card-score {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.top-card-score-value {
  font-size: var(--font-size-lg);
  font-weight: 800;
  color: var(--primary);
  line-height: 1;
}

.top-card-score-label {
  font-size: var(--font-size-xs);
  color: var(--gray-400);
  margin-top: 2rpx;
}

.top-card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-1);
  margin-top: var(--space-1);
}

.top-card-meta-item {
  font-size: var(--font-size-sm);
  color: var(--text-color-secondary);
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.top-card-meta-item.highlight {
  color: var(--danger);
  font-weight: 600;
}

/* 价格对比信息 */
.top-card-price-info {
  margin-top: var(--space-1);
  padding: var(--space-1) 0;
  border-top: 1rpx dashed var(--border-color);
}

.price-compare {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--font-size-xs);
}

.price-label {
  color: var(--text-color-secondary);
}

.price-filing {
  color: var(--text-color-secondary);
  text-decoration: line-through;
}

.price-diff {
  font-weight: 600;
  font-size: var(--font-size-xs);
}

.price-diff.up {
  color: var(--danger);
}

.price-diff.down {
  color: var(--success);
}

.price-date {
  margin-top: 2rpx;
}

.price-date-text {
  font-size: var(--font-size-xs);
  color: var(--text-color-secondary);
}

.top-card-data-source {
  margin-top: var(--space-1);
  padding-top: var(--space-1);
  border-top: 1rpx dashed var(--border-color);
}

.data-source-text {
  font-size: var(--font-size-xs);
  color: var(--text-color-secondary);
  font-style: italic;
}

/* 排名徽章 */
.rank-badge {
  position: absolute;
  top: 0;
  left: 0;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-sm);
  font-weight: 800;
  color: white;
  border-bottom-right-radius: var(--radius-md);
  z-index: 10;
}

.rank-badge.gold {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 215, 0, 0.4);
}

.rank-badge.silver {
  background: linear-gradient(135deg, #C0C0C0 0%, #A0A0A0 100%);
  box-shadow: 0 4rpx 12rpx rgba(192, 192, 192, 0.4);
}

.rank-badge.bronze {
  background: linear-gradient(135deg, #CD7F32 0%, #B87333 100%);
  box-shadow: 0 4rpx 12rpx rgba(205, 127, 50, 0.4);
}

/* ========== 推荐理由 - 引用样式（双列适配） ========== */
.top-card-reasons {
  padding: var(--space-2);
  padding-top: 0;
  border-top: 1rpx solid var(--border-color);
  flex: 1;
}

.reasons-title {
  font-size: var(--font-size-xs);
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: var(--space-1);
  display: flex;
  align-items: center;
  gap: var(--space-1);
}

.reasons-list {
  border-left: 3rpx solid var(--primary);
  padding-left: var(--space-2);
  background: var(--gray-50);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  padding: var(--space-1) var(--space-2);
}

.reason-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: var(--space-1);
}

.reason-item:last-child {
  margin-bottom: 0;
}

.reason-dot {
  width: 8rpx;
  height: 8rpx;
  background: var(--primary);
  border-radius: 50%;
  margin-right: var(--space-1);
  margin-top: 10rpx;
  flex-shrink: 0;
}

.reason-text {
  flex: 1;
  font-size: var(--font-size-xs);
  color: var(--text-color-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ========== 优缺点标签（双列适配） ========== */
.top-card-tags {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  padding: 0 var(--space-2) var(--space-2);
}

.pros-tags, .cons-tags {
  width: 100%;
}

.pros-tags-title, .cons-tags-title {
  font-size: var(--font-size-xs);
  font-weight: 600;
  margin-bottom: var(--space-1);
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.pros-tags-title {
  color: var(--success);
}

.cons-tags-title {
  color: var(--warning);
}

.pros-tags-list, .cons-tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.tag-success {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 10rpx;
  background: var(--success-light);
  color: var(--success);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  font-weight: 500;
}

.tag-warning {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 10rpx;
  background: var(--warning-light);
  color: var(--warning);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  font-weight: 500;
}

/* ========== 查看详情按钮（双列适配） ========== */
.top-card-action {
  padding: 0 var(--space-2) var(--space-2);
  margin-top: auto;
}

.btn-detail {
  width: 100%;
  height: 64rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: white;
  border-radius: var(--radius-md);
  font-size: var(--font-size-sm);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
  transition: all 0.2s ease;
}

.btn-detail:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(37, 99, 235, 0.2);
}

/* ========== 对比表格 ========== */
.compare-table {
  background: var(--background-color-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: var(--space-4);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--border-color);
}

.table-header {
  display: flex;
  background: var(--gray-800);
}

.th-cell {
  flex: 1;
  padding: var(--space-3) var(--space-2);
  text-align: center;
  font-size: var(--font-size-sm);
  color: white;
  border-right: 1rpx solid rgba(255, 255, 255, 0.1);
}

.th-cell:last-child {
  border-right: none;
}

.th-label {
  flex: 0.7;
  font-weight: 600;
}

.th-rank {
  font-size: var(--font-size-md);
  font-weight: 700;
  margin-bottom: 4rpx;
}

.th-name {
  font-size: var(--font-size-xs);
  opacity: 0.9;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid var(--border-color);
}

.table-row:last-child {
  border-bottom: none;
}

.table-row:nth-child(odd) {
  background: var(--gray-50);
}

.table-row:nth-child(even) {
  background: var(--background-color-white);
}

.td-label {
  flex: 0.7;
  padding: var(--space-3) var(--space-2);
  text-align: center;
  font-size: var(--font-size-sm);
  color: var(--text-color-secondary);
  background: var(--gray-100);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
}

.td-cell {
  flex: 1;
  padding: var(--space-3) var(--space-2);
  text-align: center;
  font-size: var(--font-size-sm);
  color: var(--text-color);
  border-right: 1rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
}

.td-cell:last-child {
  border-right: none;
}

.td-price {
  color: var(--danger);
  font-weight: 600;
}

.td-price-date {
  color: var(--text-color-secondary);
  font-size: var(--font-size-xs);
  margin-left: 4rpx;
}

.td-filing-price {
  color: var(--text-color-secondary);
  font-weight: 500;
}

.td-price-diff {
  font-weight: 600;
}

.td-price-diff.up {
  color: var(--danger);
}

.td-price-diff.down {
  color: var(--success);
}

.td-score {
  color: var(--primary);
  font-weight: 700;
  font-size: var(--font-size-md);
}

/* ========== 底部操作按钮 ========== */
.footer-actions {
  display: flex;
  gap: var(--space-3);
  margin-top: var(--space-5);
  padding-bottom: var(--space-5);
}

.btn-rematch, .btn-share {
  flex: 1;
  height: 96rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.2s ease;
}

.btn-rematch {
  background: var(--gray-100);
  color: var(--gray-700);
}

.btn-rematch:active {
  background: var(--gray-200);
  transform: scale(0.98);
}

.btn-share {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.35);
}

.btn-share:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(37, 99, 235, 0.25);
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx var(--space-4);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: var(--space-3);
  opacity: 0.6;
}

.empty-text {
  font-size: var(--font-size-md);
  color: var(--text-color-secondary);
  margin-bottom: var(--space-4);
  text-align: center;
  line-height: 1.6;
}

.empty-btn {
  width: 320rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: white;
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.35);
}

/* ========== 兼容旧版样式（保留但标记为废弃） ========== */
/* 详细推荐 - 旧版样式，保留以兼容现有数据 */
.detail-section {
  background: var(--background-color-white);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--border-color);
}

.detail-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-3);
}

.detail-rank {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-sm);
  font-weight: 700;
  margin-right: var(--space-2);
}

.detail-name {
  flex: 1;
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--text-color);
}

.detail-score {
  font-size: var(--font-size-xl);
  font-weight: 800;
  color: var(--primary);
}

.detail-reasons {
  margin-bottom: var(--space-3);
}

.detail-pros-cons {
  display: flex;
  gap: var(--space-3);
  margin-bottom: var(--space-3);
}

.pros, .cons {
  flex: 1;
  padding: var(--space-2);
  border-radius: var(--radius-md);
  font-size: var(--font-size-sm);
}

.pros {
  background: var(--success-light);
  color: var(--success);
}

.cons {
  background: var(--warning-light);
  color: var(--warning);
}

.pros-title, .cons-title {
  font-weight: 700;
  margin-bottom: var(--space-1);
  font-size: var(--font-size-sm);
}

.detail-actions {
  display: flex;
  gap: var(--space-2);
}

.btn-favorite {
  flex: 1;
  height: 72rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  background: var(--warning-light);
  color: var(--warning);
}
