/**
 * 小区详情页样式 - 专业版UI
 */

/* ========== 加载状态 ========== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.loading-text {
  font-size: var(--font-size-md);
  color: var(--text-color-secondary);
}

/* ========== 顶部信息卡片 - 带渐变背景 ========== */
.header-card {
  position: relative;
  background-color: var(--background-color-white);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--border-color);
  overflow: hidden;
}

/* 渐变背景装饰 */
.header-gradient-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(135deg, var(--primary-bg) 0%, var(--background-color-white) 100%);
  z-index: 0;
}

/* 小区名称和区域标签 */
.community-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.community-name {
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: var(--gray-900);
  line-height: 1.3;
}

.district-tag {
  flex-shrink: 0;
}

/* 地址行 */
.address-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 30rpx;
  padding: 16rpx 20rpx;
  background-color: var(--gray-50);
  border-radius: var(--radius-md);
}

.address-icon {
  font-size: var(--font-size-md);
  flex-shrink: 0;
}

.address-text {
  flex: 1;
  font-size: var(--font-size-sm);
  color: var(--text-color-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow-icon {
  font-size: var(--font-size-lg);
  color: var(--gray-400);
  flex-shrink: 0;
}

/* 当前均价 - 突出显示 */
.price-highlight {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.price-label {
  font-size: var(--font-size-sm);
  color: var(--text-color-secondary);
}

.price-display {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.price-number {
  font-size: var(--font-size-3xl);
  font-weight: 700;
  line-height: 1;
}

.price-unit {
  font-size: var(--font-size-sm);
  color: var(--text-color-secondary);
}

/* ========== 基本信息卡片 ========== */
.info-card {
  margin-bottom: var(--space-3);
}

/* 区块标题 */
.section-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 24rpx;
  padding-left: 20rpx;
  border-left: 8rpx solid var(--primary);
}

/* 信息网格 - 2x2布局，图标+文字 */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.grid-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  background-color: var(--gray-50);
  border-radius: var(--radius-md);
}

.grid-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: 32rpx;
  flex-shrink: 0;
}

.icon-calendar {
  background-color: #DBEAFE;
}

.icon-home {
  background-color: #D1FAE5;
}

.icon-building {
  background-color: #FEF3C7;
}

.icon-area {
  background-color: #F3E8FF;
}

.grid-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.grid-label {
  font-size: var(--font-size-xs);
  color: var(--text-color-secondary);
}

.grid-value {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--gray-700);
}

.grid-sub {
  font-size: var(--font-size-xs);
  color: var(--gray-400);
}

/* ========== 价格信息卡片 ========== */
.price-card {
  margin-bottom: var(--space-3);
}

/* 总价估算 */
.total-price-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, var(--primary-bg) 0%, #EFF6FF 100%);
  border-radius: var(--radius-md);
}

.total-label {
  font-size: var(--font-size-sm);
  color: var(--text-color-secondary);
}

.total-value {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--primary);
}

/* 涨跌幅行 */
.change-row {
  display: flex;
  gap: 40rpx;
}

.change-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.change-label {
  font-size: var(--font-size-sm);
  color: var(--text-color-secondary);
}

.change-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: var(--font-size-sm);
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-full);
}

.change-arrow {
  font-size: var(--font-size-xs);
}

/* 上涨红色 */
.tag-up {
  color: var(--danger);
  background-color: var(--danger-light);
}

/* 下跌绿色 */
.tag-down {
  color: var(--success);
  background-color: var(--success-light);
}

/* 持平灰色 */
.tag-flat {
  color: var(--gray-500);
  background-color: var(--gray-100);
}

/* ========== 走势图卡片 - 卡片容器，圆角阴影 ========== */
.chart-card {
  margin-bottom: var(--space-3);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
}

/* 价格历史列表 */
.price-history-list {
  margin-top: 20rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.history-item:last-child {
  border-bottom: none;
}

.history-month {
  width: 100rpx;
  font-size: var(--font-size-sm);
  color: var(--text-color-secondary);
  text-align: left;
  flex-shrink: 0;
}

.history-bar-container {
  flex: 1;
  height: 32rpx;
  background-color: var(--gray-100);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.history-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--primary) 0%, var(--primary-light) 100%);
  border-radius: var(--radius-full);
  transition: width 0.5s ease;
}

.history-price-wrap {
  width: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.history-price {
  font-size: var(--font-size-sm);
  color: var(--text-color);
  font-weight: 600;
}

.history-change {
  font-size: var(--font-size-xs);
  margin-top: 4rpx;
}

.text-up {
  color: var(--danger);
}

.text-down {
  color: var(--success);
}

/* ========== 周边配套卡片 - 分类展示，彩色图标 ========== */
.facility-card {
  margin-bottom: var(--space-3);
}

.facility-section {
  margin-bottom: 32rpx;
}

.facility-section:last-child {
  margin-bottom: 0;
}

.facility-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.facility-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  flex-shrink: 0;
}

.icon-metro {
  background-color: #DBEAFE;
}

.icon-school {
  background-color: #D1FAE5;
}

.icon-hospital {
  background-color: #FEE2E2;
}

.icon-mall {
  background-color: #FEF3C7;
}

.facility-title {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--text-color);
}

.facility-content {
  padding-left: 68rpx;
}

.facility-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.facility-item:last-child {
  border-bottom: none;
}

.facility-name {
  flex: 1;
  font-size: var(--font-size-sm);
  color: var(--gray-700);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.facility-tag {
  flex-shrink: 0;
}

.metro-line-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: 500;
  background-color: var(--primary-bg);
  color: var(--primary);
}

.school-type-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: 500;
  background-color: var(--success-light);
  color: var(--success);
}

.distance-tag {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: 500;
  background-color: var(--gray-100);
  color: var(--gray-600);
}

/* ========== 户型卡片 - 标签组形式 ========== */
.layout-card {
  margin-bottom: var(--space-3);
}

.layout-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.layout-tag {
  padding: 12rpx 24rpx;
  font-size: var(--font-size-sm);
}

/* ========== 底部操作栏 - 固定在底部，带安全区域适配 ========== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background-color: var(--background-color-white);
  border-top: 1rpx solid var(--border-color);
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 100;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: var(--font-size-md);
  font-weight: 600;
  border-radius: var(--radius-md);
}

.btn-icon {
  font-size: var(--font-size-md);
}

/* 底部安全区域 - 为内容区域添加底部间距 */
.container {
  padding-bottom: 140rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-text {
  font-size: var(--font-size-md);
  color: var(--text-color-secondary);
}
