  <!-- 产品特点区域 -->
  <view class="trust-section">
    <view class="trust-header">
      <view class="trust-badge">
        <view class="trust-badge-icon">🛡️</view>
        <text class="trust-badge-text">产品特点</text>
      </view>
    </view>
    <view class="trust-list">
      <view class="trust-item">
        <view class="trust-icon trust-data">🤖</view>
        <view class="trust-content">
          <text class="trust-title">多AI讨论</text>
          <text class="trust-desc">多AI专家深度讨论</text>
        </view>
      </view>
      <view class="trust-item">
        <view class="trust-icon trust-ai">🎯</view>
        <view class="trust-content">
          <text class="trust-title">精准需求匹配</text>
          <text class="trust-desc">8维度深度分析您的需求</text>
        </view>
      </view>
      <view class="trust-item">
        <view class="trust-icon trust-update">📍</view>
        <view class="trust-content">
          <text class="trust-title">全深圳覆盖</text>
          <text class="trust-desc">涵盖10大区域真实小区</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <view class="footer-icon">💡</view>
    <text class="footer-text">已有 <text class="footer-highlight">1000+</text> 用户通过AI找到理想房源</text>
  </view>
</view>
