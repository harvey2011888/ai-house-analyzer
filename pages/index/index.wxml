<!-- 首页 - 专业版 -->
<view class="home-container">
  <!-- 顶部欢迎区域 - 渐变背景 -->
  <view class="welcome-section">
    <!-- 数据可信度标签 -->
    <view class="welcome-badge">
      <view class="badge-icon">✓</view>
      <text class="badge-text">基于真实成交数据</text>
    </view>
    
    <!-- 品牌标识区域 - 大字号标题 -->
    <view class="brand-section">
      <view class="brand-title">AI购房助手</view>
      <view class="brand-subtitle">专业的深圳购房智能推荐</view>
    </view>
    
    <!-- 描述文字 -->
    <view class="welcome-desc">
      <text class="desc-line">基于AI大模型，结合深圳真实房价数据</text>
      <text class="desc-line">为您推荐最合适的小区</text>
    </view>
  </view>

  <!-- 开始咨询按钮 - 渐变色彩 + 阴影 + 点击动画 -->
  <view class="start-section">
    <button class="start-btn" bindtap="onStartChat" hover-class="start-btn-hover">
      <view class="btn-icon">💬</view>
      <view class="btn-content">
        <text class="btn-text">开始咨询</text>
        <text class="btn-subtext">AI为您推荐最适合的房源</text>
      </view>
      <view class="btn-arrow">→</view>
    </button>
  </view>

