/**
 * 首页样式 - 专业版
 * 使用新配色方案：--primary #2563EB, --primary-light #3B82F6
 * 字体层级：标题 40rpx，副标题 32rpx，正文 28rpx
 */

.home-container {
  min-height: 100vh;
  background: var(--gray-50);
  padding: var(--space-3);
  padding-bottom: calc(var(--space-5) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-5) + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ==================== 欢迎区域 - 渐变背景 ==================== */
.welcome-section {
  text-align: center;
  padding: var(--space-6) var(--space-4);
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  border-radius: var(--radius-xl);
  margin-bottom: var(--space-4);
  position: relative;
  overflow: hidden;
}

/* 装饰性背景元素 */
.welcome-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.welcome-section::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

/* 数据可信度徽章 - 使用 --tag-primary 样式 */
.welcome-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border-radius: var(--radius-full);
  padding: var(--space-1) var(--space-3);
  margin-bottom: var(--space-4);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.badge-icon {
  width: 32rpx;
  height: 32rpx;
  background: var(--success);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-xs);
  color: white;
  margin-right: var(--space-1);
  font-weight: bold;
}

.badge-text {
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.95);
  font-weight: 500;
}

/* 品牌标识区域 - 大字号标题 */
.brand-section {
  position: relative;
  z-index: 1;
  margin-bottom: var(--space-3);
}

.brand-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: var(--space-2);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  letter-spacing: 2rpx;
}

.brand-subtitle {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 600;
}

.welcome-desc {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  position: relative;
  z-index: 1;
}

.desc-line {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
}

/* ==================== 开始按钮 - 渐变色彩 + 阴影 + 点击动画 ==================== */
.start-section {
  padding: var(--space-2) 0 var(--space-4);
}

.start-btn {
  width: 100%;
  height: 180rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  border-radius: var(--radius-xl);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-5);
  border: none;
  box-shadow: var(--shadow-lg);
  position: relative;
  overflow: hidden;
  transition: all 0.2s ease;
}

.start-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

/* 点击缩放动画 - transform: scale(0.96) */
.start-btn-hover {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

.start-btn-hover::before {
  left: 100%;
}

.btn-icon {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  backdrop-filter: blur(4rpx);
}

.btn-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  flex: 1;
  margin-left: var(--space-3);
}

.btn-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 6rpx;
}

.btn-subtext {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.btn-arrow {
  width: 48rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-lg);
  color: #ffffff;
  font-weight: bold;
}

/* ==================== 热门小区 - 卡片样式 ==================== */
.hot-section {
  margin-top: var(--space-2);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.section-title {
  display: flex;
  align-items: center;
}

.title-icon {
  font-size: 32rpx;
  margin-right: var(--space-1);
}

.title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--gray-900);
}

.title-sub {
  font-size: 24rpx;
  color: var(--gray-600);
  background: var(--gray-100);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
}

.hot-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

/* 卡片样式 - 圆角 16rpx，阴影 --shadow-md */
.hot-item {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: var(--shadow-md);
  transition: all 0.2s ease;
}

.hot-item-hover {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

/* 图片区域 */
.hot-image-wrapper {
  position: relative;
  height: 200rpx;
  overflow: hidden;
}

/* 图片占位区域 - 使用渐变背景模拟 */
.hot-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 64rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* 渐变遮罩 */
.hot-image-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.4) 0%, transparent 100%);
  pointer-events: none;
}

/* 排名标识 */
.hot-rank {
  position: absolute;
  top: var(--space-2);
  left: var(--space-2);
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.9) 100%);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-md);
  font-weight: 700;
  color: var(--primary);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

/* 前三名特殊样式 */
.hot-item:nth-child(1) .hot-rank {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: white;
}

.hot-item:nth-child(2) .hot-rank {
  background: linear-gradient(135deg, #C0C0C0 0%, #A0A0A0 100%);
  color: white;
}

.hot-item:nth-child(3) .hot-rank {
  background: linear-gradient(135deg, #CD7F32 0%, #B87333 100%);
  color: white;
}

/* 内容区域 */
.hot-content {
  padding: var(--space-3);
}

.hot-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-2);
}

.hot-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--gray-900);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-trend {
  font-size: 24rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  margin-left: var(--space-2);
}

.hot-trend.up {
  background: var(--danger-light);
  color: var(--danger);
}

.hot-trend.down {
  background: var(--success-light);
  color: var(--success);
}

.hot-trend.stable {
  background: var(--gray-100);
  color: var(--gray-600);
}

.hot-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-2);
}

/* 区域标签样式 */
.hot-district-tag {
  display: inline-flex;
  align-items: center;
  background: var(--primary-bg);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
}

.district-icon {
  font-size: 20rpx;
  margin-right: 4rpx;
}

.district-text {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 500;
}

.hot-price-wrapper {
  display: flex;
  align-items: baseline;
}

/* 价格使用红色（--danger）突出显示 */
.hot-price {
  font-size: 36rpx;
  color: var(--danger);
  font-weight: 700;
}

.hot-unit {
  font-size: 24rpx;
  color: var(--gray-600);
  margin-left: 4rpx;
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-1);
}

.hot-tag {
  font-size: 20rpx;
  color: var(--primary);
  background: var(--primary-bg);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-weight: 500;
}

/* ==================== 数据可信度标识 ==================== */
.trust-section {
  margin-top: var(--space-5);
  background: #ffffff;
  border-radius: 16rpx;
  padding: var(--space-4);
  box-shadow: var(--shadow-md);
}

.trust-header {
  display: flex;
  justify-content: center;
  margin-bottom: var(--space-3);
}

/* 数据可信度标签 - 使用 --tag-primary 样式 */
.trust-badge {
  display: inline-flex;
  align-items: center;
  background: var(--primary-bg);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
}

.trust-badge-icon {
  font-size: 24rpx;
  margin-right: var(--space-1);
}

.trust-badge-text {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
}

.trust-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.trust-item {
  display: flex;
  align-items: center;
  padding: var(--space-2) 0;
}

.trust-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: var(--space-3);
  flex-shrink: 0;
}

.trust-icon.trust-data {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
}

.trust-icon.trust-ai {
  background: linear-gradient(135deg, #E0E7FF 0%, #C7D2FE 100%);
}

.trust-icon.trust-update {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
}

.trust-content {
  display: flex;
  flex-direction: column;
}

.trust-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-900);
  margin-bottom: 4rpx;
}

.trust-desc {
  font-size: 24rpx;
  color: var(--gray-600);
}

/* ==================== 底部提示 ==================== */
.footer-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-5) 0 var(--space-3);
}

.footer-icon {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: var(--space-2);
}

.footer-text {
  font-size: 24rpx;
  color: var(--gray-600);
}

.footer-highlight {
  color: var(--primary);
  font-weight: 700;
  font-size: 28rpx;
}
