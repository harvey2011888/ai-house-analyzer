/**
 * 全局样式文件
 * 定义主题色变量和通用样式 - 专业版配色方案
 */

page {
  /* 主色调 - 专业蓝色系 */
  --primary: #2563EB;
  --primary-light: #3B82F6;
  --primary-dark: #1D4ED8;
  --primary-bg: #DBEAFE;
  
  /* 功能色 */
  --success: #10B981;
  --success-light: #D1FAE5;
  --warning: #F59E0B;
  --warning-light: #FEF3C7;
  --danger: #EF4444;
  --danger-light: #FEE2E2;
  --info: #6B7280;
  
  /* 中性色阶 */
  --gray-900: #111827;
  --gray-800: #1F2937;
  --gray-700: #374151;
  --gray-600: #4B5563;
  --gray-500: #6B7280;
  --gray-400: #9CA3AF;
  --gray-300: #D1D5DB;
  --gray-200: #E5E7EB;
  --gray-100: #F3F4F6;
  --gray-50: #F9FAFB;
  
  /* 文字颜色 */
  --text-color: var(--gray-900);
  --text-color-secondary: var(--gray-600);
  --text-color-light: var(--gray-400);
  
  /* 背景颜色 */
  --background-color: var(--gray-50);
  --background-color-light: var(--gray-100);
  --background-color-white: #ffffff;
  
  /* 边框颜色 */
  --border-color: var(--gray-200);
  
  /* 阴影 */
  --shadow-sm: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.1), 0 2rpx 4rpx -1rpx rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.1), 0 4rpx 6rpx -2rpx rgba(0, 0, 0, 0.05);
  --shadow-xl: 0 20rpx 25rpx -5rpx rgba(0, 0, 0, 0.1), 0 10rpx 10rpx -5rpx rgba(0, 0, 0, 0.04);
  
  /* 字体大小 */
  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-2xl: 40rpx;
  --font-size-3xl: 48rpx;
  
  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-full: 9999rpx;
  
  /* 间距 */
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 40rpx;
  --space-6: 48rpx;
  
  /* 全局字体 */
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  font-size: var(--font-size-md);
  color: var(--text-color);
  background-color: var(--background-color);
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: var(--space-3);
  box-sizing: border-box;
  min-height: 100vh;
}

/* 卡片样式 - 专业版 */
.card {
  background-color: var(--background-color-white);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--border-color);
}

/* 卡片悬停效果 */
.card-hover {
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card-hover:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

/* 标题样式 */
.title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: var(--space-2);
  line-height: 1.3;
}

/* 副标题样式 */
.subtitle {
  font-size: var(--font-size-md);
  color: var(--text-color-secondary);
  margin-bottom: var(--space-2);
  line-height: 1.5;
}

/* 主色调文字 */
.text-primary {
  color: var(--primary);
}

/* 成功色文字 */
.text-success {
  color: var(--success);
}

/* 警告色文字 */
.text-warning {
  color: var(--warning);
}

/* 危险色文字 */
.text-danger {
  color: var(--danger);
}

/* 灰色文字 */
.text-gray {
  color: var(--text-color-secondary);
}

/* 文字颜色层级 */
.text-heading {
  color: var(--gray-900);
}

.text-body {
  color: var(--gray-700);
}

.text-muted {
  color: var(--gray-500);
}

/* 文字居中 */
.text-center {
  text-align: center;
}

/* 文字右对齐 */
.text-right {
  text-align: right;
}

/* 字体加粗 */
.font-bold {
  font-weight: 700;
}

.font-semibold {
  font-weight: 600;
}

.font-medium {
  font-weight: 500;
}

/* 弹性布局 */
.flex {
  display: flex;
}

/* 垂直居中 */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 两端对齐 */
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 列布局 */
.flex-col {
  display: flex;
  flex-direction: column;
}

/* 按钮基础样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  font-weight: 500;
  transition: all 0.2s ease;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 6rpx rgba(37, 99, 235, 0.2);
}

.btn-secondary {
  background-color: var(--gray-100);
  color: var(--gray-700);
}

.btn-secondary:active {
  background-color: var(--gray-200);
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  font-weight: 500;
}

.tag-primary {
  background-color: var(--primary-bg);
  color: var(--primary);
}

.tag-success {
  background-color: var(--success-light);
  color: var(--success);
}

.tag-warning {
  background-color: var(--warning-light);
  color: var(--warning);
}

/* 底部安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 渐变背景 */
.gradient-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
}

.gradient-bg {
  background: linear-gradient(180deg, var(--primary-bg) 0%, var(--background-color) 100%);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: var(--space-3) 0;
}

/* 徽章样式 */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 12rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: 600;
}

.badge-primary {
  background-color: var(--primary);
  color: white;
}

.badge-gold {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: white;
}

.badge-silver {
  background: linear-gradient(135deg, #C0C0C0 0%, #A0A0A0 100%);
  color: white;
}

.badge-bronze {
  background: linear-gradient(135deg, #CD7F32 0%, #B87333 100%);
  color: white;
}
